{
  "name": "cloudflare-telegram-chat-mvp",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "workers/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @chat/web",
    "dev:worker": "npm run dev --workspace @chat/chat-api",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  }
}
